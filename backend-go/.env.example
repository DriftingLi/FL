# ===== 应用配置 =====
APP_ENV=development
PORT=8080

# ===== 密钥（生产环境必填，且不能为默认值）=====
SECRET_KEY=dev-secret-key
JWT_SECRET_KEY=jwt-secret-key
JWT_EXPIRES_HOURS=1

# ===== 默认账号密码（生产环境必须改为强密码）=====
# 启动时自动创建 admin / tutor / student 账号，密码由此处配置
ADMIN_DEFAULT_PASSWORD=admin123
TUTOR_DEFAULT_PASSWORD=tutor123
STUDENT_DEFAULT_PASSWORD=student123

# ===== 数据库（本地 Docker PostgreSQL）=====
DATABASE_URL=postgres://forklift:forklift123@localhost:5432/forklift_training?sslmode=disable

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173

# ===== 文件上传 =====
UPLOAD_FOLDER=
VOLUME_MOUNT_PATH=
MAX_CONTENT_LENGTH_MB=250

# ===== OpenAI =====
OPENAI_API_KEY=

# ===== Coze OAuth =====
COZE_PROJECT_ID=
COZE_OAUTH_APP_ID=
COZE_OAUTH_KID=
COZE_OAUTH_PRIVATE_KEY=
COZE_OAUTH_PRIVATE_KEY_PATH=

# ===== 残值评估模块 =====
VALUATION_PDF_OUTPUT_DIR=storage/reports
VALUATION_LOG_LEVEL=info
VALUATION_LOG_FORMAT=console
VALUATION_LOG_OUTPUT=stdout
VALUATION_DB_MAX_OPEN_CONNS=20
VALUATION_DB_MAX_IDLE_CONNS=5
VALUATION_DB_CONN_MAX_LIFETIME=3600
