# ===== 生产环境配置模板 =====
# 复制为 .env 并填入实际值；Railway 部署时通过 Railway 变量注入

# ===== 应用 =====
APP_ENV=production
PORT=8080

# ===== 密钥（生产必填，且不能为默认值）=====
SECRET_KEY=请替换为强随机字符串
JWT_SECRET_KEY=请替换为另一个强随机字符串
JWT_EXPIRES_HOURS=1

# ===== 数据库（Railway PostgreSQL 插件自动注入）=====
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# ===== CORS =====
CORS_ORIGINS=https://your-frontend-domain.example.com

# ===== 文件上传 =====
UPLOAD_FOLDER=/data/uploads
VOLUME_MOUNT_PATH=/data
MAX_CONTENT_LENGTH_MB=250

# ===== AI（智谱 GLM）=====
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.7-flash

# ===== OpenAI（备用，ZHIPU_API_KEY 为空时使用）=====
# OPENAI_API_KEY=

# ===== Coze OAuth（如需扣子智能体）=====
COZE_PROJECT_ID=
COZE_OAUTH_APP_ID=
COZE_OAUTH_KID=
COZE_OAUTH_PRIVATE_KEY=
COZE_OAUTH_PRIVATE_KEY_PATH=
