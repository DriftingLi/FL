	/*每个页面公共css */
	.uni-row {
		flex-direction: row;
	}

	.uni-column {
		flex-direction: column;
	}

	/* 全局公共样式 */
	.page-base {
		background-color: #f8f8f8;
		font-size: 28rpx;
		color: #333333;
	}

	/* 通用卡片 */
	.card {
		background-color: #ffffff;
		border-radius: 24rpx;
		padding: 24rpx;
		margin: 24rpx;
	}

	/* 通用按钮 */
	.btn-primary {
		background-color: #2979ff;
		color: #ffffff;
		border-radius: 48rpx;
		height: 88rpx;
		line-height: 88rpx;
		text-align: center;
		font-size: 32rpx;
		font-weight: bold;
	}

	.btn-primary-disabled {
		opacity: 0.5;
	}

	/* 通用输入框 */
	.input-base {
		height: 88rpx;
		border: 1rpx solid #e5e5e5;
		border-radius: 12rpx;
		padding: 0 24rpx;
		font-size: 28rpx;
		background-color: #ffffff;
	}
</style>
