<script>
	import { useAuthStore } from './stores/auth'

	// #ifdef APP-ANDROID || APP-HARMONY
	let firstBackTime = 0
	// #endif

	export default {
		onLaunch: function() {
			console.log('App Launch')
			// 启动时异步校验 token（不阻塞渲染）
			const auth = useAuthStore()
			// 使用 async/await + try/catch 避免 UTSPromise.catch 类型推断问题
			;(async () : Promise<void> => {
				try {
					await auth.validateToken()
					console.log('Token validated, isLoggedIn=', auth.isLoggedIn.value)
				} catch (e) {
					console.error('Token validate failed:', e)
				}
			})()
		},
		onShow: function() {
			console.log('App Show')
		},
		onHide: function() {
			console.log('App Hide')
		},
		// #ifdef APP-ANDROID || APP-HARMONY
		onLastPageBackPress: function() : void {
			console.log('App LastPageBackPress')
			if (firstBackTime == 0) {
				uni.showToast({
					title: '再按一次退出应用',
					position: 'bottom',
				})
				firstBackTime = Date.now()
				setTimeout(() => {
					firstBackTime = 0
				}, 2000)
			} else if (Date.now() - firstBackTime < 2000) {
				firstBackTime = Date.now()
				uni.exit()
			}
		},
		onExit: function() {
			console.log('App Exit')
		}
		// #endif
	}
</script>

