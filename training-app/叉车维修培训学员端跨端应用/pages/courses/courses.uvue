	}

	.category-item.active {
		background-color: #2979ff;
	}

	.category-text {
		font-size: 28rpx;
		color: #666666;
	}

	.category-item.active .category-text {
		color: #ffffff;
	}

	.course-scroll {
		flex: 1;
		padding: 24rpx;
		padding-bottom: 120rpx;
	}

	.course-grid {
		flex-direction: row;
		flex-wrap: wrap;
		justify-content: space-between;
	}

	.course-card {
		width: 48%;
		background-color: #ffffff;
		border-radius: 16rpx;
		overflow: hidden;
		margin-bottom: 20rpx;
		box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
	}

	.course-card-cover {
		width: 100%;
		height: 180rpx;
		background-color: #e3f2fd;
