		justify-content: center;
	}

	.course-card-icon {
		font-size: 64rpx;
	}

	.course-card-info {
		padding: 20rpx;
		flex-direction: column;
	}

	.course-card-title {
		font-size: 30rpx;
		font-weight: bold;
		color: #333333;
		margin-bottom: 8rpx;
	}

	.course-card-desc {
		font-size: 24rpx;
		color: #999999;
		margin-bottom: 16rpx;
	}

	.course-card-footer {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
	}

