# ===== 前端环境变量示例 =====
# 复制为 .env.local 后按需修改

# 子域名配置（生产环境通过 DNS A 记录指向同一服务器 IP）
# 本地开发默认使用 *.localhost 模式，需要在 hosts 文件添加：
#   127.0.0.1 training.localhost
#   127.0.0.1 valuation.localhost
#   127.0.0.1 mentor.localhost
#   127.0.0.1 manage.localhost
# 注意：管理员后台 hostname 前缀为 manage（内部类型仍为 admin）
VITE_MAIN_DOMAIN=localhost
VITE_TRAINING_SUBDOMAIN=training.localhost
VITE_VALUATION_SUBDOMAIN=valuation.localhost
VITE_MENTOR_SUBDOMAIN=mentor.localhost
VITE_ADMIN_SUBDOMAIN=manage.localhost
